@model Global_Logistics_Managemant_System_POE.Models.Contract
@{
    ViewData["Title"] = "Edit Contract";
}

<div class="page-header">
    <h1>Edit <span>Contract #@Model.ContractId</span></h1>
    <a class="btn btn-secondary" asp-action="Index">&#8592; Back</a>
</div>

<div class="card" style="max-width:800px;">
    <div asp-validation-summary="ModelOnly" class="validation-summary-errors" style="margin-bottom:1rem;"></div>

    <form asp-action="Edit" method="post" enctype="multipart/form-data">
        <input type="hidden" asp-for="ContractId" />
        <input type="hidden" asp-for="SignedAgreementPath" />

        <div class="form-grid">
            <div class="form-group">
                <label>Client</label>
                <select asp-for="ClientId" asp-items="ViewBag.Clients">
                    <option value="">-- Select Client --</option>
                </select>
                <span asp-validation-for="ClientId" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Status">Status</label>
                <select asp-for="Status" asp-items="ViewBag.Statuses">
                    <option value="">-- Select Status --</option>
                </select>
                <span asp-validation-for="Status" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="StartDate">Start Date</label>
                <input asp-for="StartDate" type="date" />
                <span asp-validation-for="StartDate" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="EndDate">End Date</label>
                <input asp-for="EndDate" type="date" />
                <span asp-validation-for="EndDate" class="field-validation-error"></span>
            </div>

            <div class="form-group full">
                <label asp-for="ServiceLevel">Service Level</label>
                <input asp-for="ServiceLevel" placeholder="e.g. Gold, Standard" />
                <span asp-validation-for="ServiceLevel" class="field-validation-error"></span>
            </div>

            <div class="form-group full">
                <label>Replace Signed Agreement (PDF, max 5MB)</label>
                @if (!string.IsNullOrEmpty(Model.SignedAgreementPath))
                {
                    <p style="font-size:.8rem;color:var(--muted);margin-bottom:.4rem;">
                        Current: <a asp-action="Download" asp-route-id="@Model.ContractId" style="color:var(--accent);">Download existing PDF</a> — upload a new file to replace it.
                    </p>
                }
                <input type="file" name="signedAgreement" accept="application/pdf" />
            </div>
        </div>

        <div style="margin-top:1.5rem;display:flex;gap:.75rem;">
            <button type="submit" class="btn btn-primary">Save Changes</button>
            <a class="btn btn-secondary" asp-action="Index">Cancel</a>
        </div>
    </form>
</div>
