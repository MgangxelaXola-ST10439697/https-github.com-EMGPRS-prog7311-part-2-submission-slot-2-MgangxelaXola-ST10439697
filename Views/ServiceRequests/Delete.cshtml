@model Global_Logistics_Managemant_System_POE.Models.ServiceRequest
@{
    ViewData["Title"] = "Delete Service Request";
    var badge = Model.Status switch
    {
        "Pending" => "badge-pending",
        "In Progress" => "badge-progress",
        "Completed" => "badge-completed",
        "Cancelled" => "badge-cancelled",
        _ => "badge-draft"
    };
}

<div class="page-header">
    <h1>Delete <span>Service Request</span></h1>
</div>

<div class="card" style="max-width:600px;border-top:3px solid var(--danger);">
    <div class="alert alert-danger">
        ⚠ Are you sure you want to delete this service request? This action cannot be undone.
    </div>

    <div class="detail-grid" style="margin-bottom:1.5rem;">
        <div class="detail-item">
            <label>Request ID</label>
            <p>#@Model.ServiceRequestId</p>
        </div>
        <div class="detail-item">
            <label>Status</label>
            <p><span class="badge @badge">@Model.Status</span></p>
        </div>
        <div class="detail-item">
            <label>Client</label>
            <p>@Model.Contract?.Client?.ClientName</p>
        </div>
        <div class="detail-item">
            <label>Contract</label>
            <p>#@Model.ContractId</p>
        </div>
        <div class="detail-item">
            <label>Cost (USD)</label>
            <p>$@Model.CostUSD.ToString("N2")</p>
        </div>
        <div class="detail-item">
            <label>Cost (ZAR)</label>
            <p>R @Model.CostZAR.ToString("N2")</p>
        </div>
        <div class="detail-item" style="grid-column:1/-1;">
            <label>Description</label>
            <p>@Model.Description</p>
        </div>
    </div>

    <form asp-action="Delete" method="post" style="display:flex;gap:.75rem;">
        <input type="hidden" asp-for="ServiceRequestId" />
        <button type="submit" class="btn btn-danger">Yes, Delete</button>
        <a class="btn btn-secondary" asp-action="Index">Cancel</a>
    </form>
</div>
