@model Global_Logistics_Managemant_System_POE.Models.ServiceRequest
@{
    ViewData["Title"] = "Edit Service Request";
}

<div class="page-header">
    <h1>Edit <span>Service Request #@Model.ServiceRequestId</span></h1>
    <a class="btn btn-secondary" asp-action="Index">&#8592; Back</a>
</div>

<div class="card" style="max-width:720px;">
    <div asp-validation-summary="ModelOnly" class="validation-summary-errors" style="margin-bottom:1rem;"></div>

    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="ServiceRequestId" />

        <div class="form-grid">
            <div class="form-group full">
                <label>Contract (Active only)</label>
                <select asp-for="ContractId" asp-items="ViewBag.Contracts">
                    <option value="">-- Select Contract --</option>
                </select>
                <span asp-validation-for="ContractId" class="field-validation-error"></span>
            </div>

            <div class="form-group full">
                <label asp-for="Description">Description</label>
                <textarea asp-for="Description"></textarea>
                <span asp-validation-for="Description" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Status">Status</label>
                <select asp-for="Status" asp-items="ViewBag.Statuses">
                    <option value="">-- Select Status --</option>
                </select>
                <span asp-validation-for="Status" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="CostUSD">Cost (USD)</label>
                <input asp-for="CostUSD" type="number" step="0.01" min="0" />
                <span asp-validation-for="CostUSD" class="field-validation-error"></span>
            </div>

            <div class="form-group" style="grid-column:1/-1;">
                <label>Current ZAR Cost</label>
                <p style="padding:.55rem 0;color:var(--success);font-weight:600;">R @Model.CostZAR.ToString("N2") <span style="font-weight:400;color:var(--muted);font-size:.8rem;">(will be recalculated on save)</span></p>
            </div>
        </div>

        <div style="margin-top:1.5rem;display:flex;gap:.75rem;">
            <button type="submit" class="btn btn-primary">Save Changes</button>
            <a class="btn btn-secondary" asp-action="Index">Cancel</a>
        </div>
    </form>
</div>
