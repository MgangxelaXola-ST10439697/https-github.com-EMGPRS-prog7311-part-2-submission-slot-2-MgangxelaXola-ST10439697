@model Global_Logistics_Managemant_System_POE.Models.Client
@{
    ViewData["Title"] = "Delete Client";
}

<div class="page-header">
    <h1>Delete <span>Client</span></h1>
</div>

<div class="card" style="max-width:600px;border-top:3px solid var(--danger);">
    <div class="alert alert-danger">
        ⚠ Are you sure you want to delete this client? This action cannot be undone.
    </div>

    <div class="detail-grid" style="margin-bottom:1.5rem;">
        <div class="detail-item">
            <label>Client Name</label>
            <p>@Model.ClientName</p>
        </div>
        <div class="detail-item">
            <label>Region</label>
            <p>@Model.Region</p>
        </div>
        <div class="detail-item" style="grid-column:1/-1;">
            <label>Contact Details</label>
            <p>@Model.ContactDetails</p>
        </div>
        @if (Model.Contracts != null && Model.Contracts.Any())
        {
            <div class="detail-item" style="grid-column:1/-1;">
                <label>Linked Contracts</label>
                <p style="color:var(--danger);">@Model.Contracts.Count contract(s) will be affected.</p>
            </div>
        }
    </div>

    <form asp-action="Delete" method="post" style="display:flex;gap:.75rem;">
        <input type="hidden" asp-for="ClientId" />
        <button type="submit" class="btn btn-danger">Yes, Delete</button>
        <a class="btn btn-secondary" asp-action="Index">Cancel</a>
    </form>
</div>
