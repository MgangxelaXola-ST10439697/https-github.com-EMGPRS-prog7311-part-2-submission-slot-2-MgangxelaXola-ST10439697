@model Global_Logistics_Managemant_System_POE.Models.Client
@{
    ViewData["Title"] = "Client Details";
}

<div class="page-header">
    <h1>Client <span>Details</span></h1>
    <div class="action-row">
        <a class="btn btn-info" asp-action="Edit" asp-route-id="@Model.ClientId">Edit</a>
        <a class="btn btn-secondary" asp-action="Index">&#8592; Back</a>
    </div>
</div>

<div class="card" style="margin-bottom:1.5rem;">
    <div style="font-family:'Barlow Condensed',sans-serif;font-size:1rem;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);margin-bottom:1rem;">Client Information</div>
    <div class="detail-grid">
        <div class="detail-item">
            <label>Client Name</label>
            <p>@Model.ClientName</p>
        </div>
        <div class="detail-item">
            <label>Region</label>
            <p>@Model.Region</p>
        </div>
        <div class="detail-item" style="grid-column:1/-1;">
            <label>Contact Details</label>
            <p>@Model.ContactDetails</p>
        </div>
    </div>
</div>

@if (Model.Contracts != null && Model.Contracts.Any())
{
    <div class="card">
        <div style="font-family:'Barlow Condensed',sans-serif;font-size:1rem;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);margin-bottom:1rem;">Contracts (@Model.Contracts.Count)</div>
        <div class="tbl-wrap">
            <table>
                <thead>
                    <tr>
                        <th>Contract ID</th>
                        <th>Start Date</th>
                        <th>End Date</th>
                        <th>Status</th>
                        <th>Service Level</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var contract in Model.Contracts)
                    {
                        <tr>
                            <td>#@contract.ContractId</td>
                            <td>@contract.StartDate.ToString("dd MMM yyyy")</td>
                            <td>@contract.EndDate.ToString("dd MMM yyyy")</td>
                            <td>
                                @{
                                    var badgeClass = contract.Status switch
                                    {
                                        "Active" => "badge-active",
                                        "Draft" => "badge-draft",
                                        "Expired" => "badge-expired",
                                        "On Hold" => "badge-hold",
                                        _ => "badge-draft"
                                    };
                                }
                                <span class="badge @badgeClass">@contract.Status</span>
                            </td>
                            <td>@contract.ServiceLevel</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
else
{
    <div class="card" style="color:var(--muted);font-size:.9rem;">No contracts linked to this client yet.</div>
}
